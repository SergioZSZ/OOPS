<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns="http://example.org/oops-plus-test#"
    xmlns:base="http://example.org/oops-plus-test#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xml:base="http://example.org/oops-plus-test">

    <owl:Ontology rdf:about="http://example.org/oops-plus-test">
        <rdfs:label>OOPS plus LLM checker test ontology</rdfs:label>
        <rdfs:comment>
            Small ontology designed to make several LLM-based OOPS checkers visible in reports.
        </rdfs:comment>
    </owl:Ontology>

    <!-- P10: siblings under the same parent without owl:disjointWith axioms. -->
    <owl:Class rdf:about="#PersonRole">
        <rdfs:label>Person role</rdfs:label>
        <rdfs:comment>Root class used to test missing disjointness between sibling classes.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Student">
        <rdfs:subClassOf rdf:resource="#PersonRole"/>
        <rdfs:label>Student</rdfs:label>
        <rdfs:comment>A person enrolled in an educational activity.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Employee">
        <rdfs:subClassOf rdf:resource="#PersonRole"/>
        <rdfs:label>Employee</rdfs:label>
        <rdfs:comment>A person employed by an organization.</rdfs:comment>
    </owl:Class>

    <!-- P07: translated name should contain an explicit disjunction. -->
    <owl:Class rdf:about="#LibroOArticulo">
        <rdfs:label>Libro o articulo</rdfs:label>
        <rdfs:comment>Spanish class name intended to be translated as Book Or Article.</rdfs:comment>
    </owl:Class>

    <!-- P21: translated name should contain "other". -->
    <owl:Class rdf:about="#Otro">
        <rdfs:label>Otro</rdfs:label>
        <rdfs:comment>Spanish class name intended to be translated as Other.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Publication">
        <rdfs:label>Publication</rdfs:label>
        <rdfs:comment>A published research output.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Author">
        <rdfs:label>Author</rdfs:label>
        <rdfs:comment>A person who writes a publication.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#ResearchProject">
        <rdfs:label>Research project</rdfs:label>
        <rdfs:comment>A project funded to conduct research work.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Organization">
        <rdfs:label>Organization</rdfs:label>
        <rdfs:comment>An institution or company.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Grant">
        <rdfs:label>Grant</rdfs:label>
        <rdfs:comment>Funding awarded to a project.</rdfs:comment>
    </owl:Class>

    <!-- P03: Spanish "es" should be translated as "is". -->
    <owl:ObjectProperty rdf:about="#es">
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="#PersonRole"/>
        <rdfs:label>es</rdfs:label>
        <rdfs:comment>Spanish property name intended to be translated as is.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- P12: equivalent object properties not declared with owl:equivalentProperty. -->
    <owl:ObjectProperty rdf:about="#createdBy">
        <rdfs:domain rdf:resource="#Publication"/>
        <rdfs:range rdf:resource="#Author"/>
        <rdfs:label>created by</rdfs:label>
        <rdfs:comment>Links a publication with its creator.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasAuthor">
        <rdfs:domain rdf:resource="#Publication"/>
        <rdfs:range rdf:resource="#Author"/>
        <rdfs:label>has author</rdfs:label>
        <rdfs:comment>Links a publication with its author.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#fundedBy">
        <rdfs:domain rdf:resource="#ResearchProject"/>
        <rdfs:range rdf:resource="#Organization"/>
        <rdfs:label>funded by</rdfs:label>
        <rdfs:comment>Links a project with the organization that funds it.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#financedBy">
        <rdfs:domain rdf:resource="#ResearchProject"/>
        <rdfs:range rdf:resource="#Organization"/>
        <rdfs:label>financed by</rdfs:label>
        <rdfs:comment>Links a project with the organization that finances it.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- P12: equivalent datatype properties not declared with owl:equivalentProperty. -->
    <owl:DatatypeProperty rdf:about="#startDate">
        <rdfs:domain rdf:resource="#ResearchProject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>start date</rdfs:label>
        <rdfs:comment>The date when a project starts.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#beginDate">
        <rdfs:domain rdf:resource="#ResearchProject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>begin date</rdfs:label>
        <rdfs:comment>The date when a project begins.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#fundingAmount">
        <rdfs:domain rdf:resource="#Grant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>funding amount</rdfs:label>
        <rdfs:comment>The amount of money granted.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#grantAmount">
        <rdfs:domain rdf:resource="#Grant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label>grant amount</rdfs:label>
        <rdfs:comment>The amount of money awarded by a grant.</rdfs:comment>
    </owl:DatatypeProperty>

</rdf:RDF>
