<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://example.org/oops-test#"
    xml:base="http://example.org/oops-test"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:dcterms="http://purl.org/dc/terms/">

    <owl:Ontology rdf:about="http://example.org/oops-test">
        <rdfs:label>Simple OOPS test ontology</rdfs:label>
        <rdfs:comment>A small ontology for testing OOPS and OOPS+ without external imports.</rdfs:comment>
        <dcterms:title>Simple OOPS test ontology</dcterms:title>
        <dcterms:creator>Test user</dcterms:creator>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>

    <owl:Class rdf:about="http://example.org/oops-test#Person">
        <rdfs:label>Person</rdfs:label>
        <rdfs:comment>A human being.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/oops-test#Course">
        <rdfs:label>Course</rdfs:label>
        <rdfs:comment>An educational course.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/oops-test#Enrollment">
        <rdfs:label>Enrollment</rdfs:label>
        <rdfs:comment>The participation of a person in a course.</rdfs:comment>
    </owl:Class>

    <owl:ObjectProperty rdf:about="http://example.org/oops-test#hasEnrollment">
        <rdfs:label>has enrollment</rdfs:label>
        <rdfs:comment>Relates a person to an enrollment.</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/oops-test#Person"/>
        <rdfs:range rdf:resource="http://example.org/oops-test#Enrollment"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/oops-test#enrolledIn">
        <rdfs:label>enrolled in</rdfs:label>
        <rdfs:comment>Relates an enrollment to a course.</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/oops-test#Enrollment"/>
        <rdfs:range rdf:resource="http://example.org/oops-test#Course"/>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/oops-test#personName">
        <rdfs:label>person name</rdfs:label>
        <rdfs:comment>The name of a person.</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/oops-test#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/oops-test#courseTitle">
        <rdfs:label>course title</rdfs:label>
        <rdfs:comment>The title of a course.</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/oops-test#Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

</rdf:RDF>